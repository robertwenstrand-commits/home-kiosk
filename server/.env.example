# Copy this to .env and fill in your values

# Camera - Wyze RTSP URL (enable in Wyze app: Account > Advanced > RTSP)
# Format: rtsp://username:password@camera-ip/live
WYZE_RTSP_URL=

# Google Calendar - comma-separated calendar IDs
# Find IDs in Google Calendar settings > [Calendar] > Integrate calendar
GOOGLE_CALENDAR_IDS=primary

# How often to sync calendar from Google (seconds). Default 15 minutes.
CALENDAR_SYNC_INTERVAL=900

# App network settings
HOST=0.0.0.0
PORT=2004

# Path to your Google OAuth credentials JSON (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Display name shown in the top bar
APP_TITLE=Home
